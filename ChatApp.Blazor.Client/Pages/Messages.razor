@page "/messages"
@attribute [Authorize]
@inject UserState UserState

<PageTitle>Messages - ChatApp</PageTitle>

<MudPaper Elevation="0" Class="pa-4">
    <MudText Typo="Typo.h4" Class="mb-4">
        <MudIcon Icon="@Icons.Material.Filled.ChatBubbleOutline" Class="mr-2" />
        Messages
    </MudText>

    <MudGrid>
        <!-- Messages List Section -->
        <MudItem xs="12" md="4">
            <MudPaper Elevation="2" Class="pa-3" Style="height: calc(100vh - 200px); overflow-y: auto;">
                <MudText Typo="Typo.h6" Class="mb-3">Conversations</MudText>

                <MudList>
                    <MudListItem>
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="pa-2">
                            <MudAvatar Color="Color.Primary" Size="Size.Medium">JD</MudAvatar>
                            <MudStack Spacing="0" Style="flex: 1;">
                                <MudText Typo="Typo.body1">John Doe</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Hey, how are you?</MudText>
                            </MudStack>
                        </MudStack>
                    </MudListItem>
                    <MudDivider />

                    <MudListItem>
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="pa-2">
                            <MudAvatar Color="Color.Secondary" Size="Size.Medium">JS</MudAvatar>
                            <MudStack Spacing="0" Style="flex: 1;">
                                <MudText Typo="Typo.body1">Jane Smith</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Let's schedule a meeting</MudText>
                            </MudStack>
                        </MudStack>
                    </MudListItem>
                    <MudDivider />
                </MudList>

                <MudAlert Severity="Severity.Info" Class="mt-4">
                    <MudText Typo="Typo.body2">
                        This is a placeholder for the messages feature. Full messaging functionality will be implemented soon.
                    </MudText>
                </MudAlert>
            </MudPaper>
        </MudItem>

        <!-- Chat Area Section -->
        <MudItem xs="12" md="8">
            <MudPaper Elevation="2" Class="pa-3" Style="height: calc(100vh - 200px); display: flex; flex-direction: column;">
                <MudStack Justify="Justify.Center" AlignItems="AlignItems.Center" Style="flex: 1;">
                    <MudIcon Icon="@Icons.Material.Filled.ChatBubbleOutline"
                             Size="Size.Large"
                             Color="Color.Primary"
                             Style="font-size: 80px; opacity: 0.3;" />
                    <MudText Typo="Typo.h6" Color="Color.Secondary">Select a conversation to start chatting</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary" Align="Align.Center">
                        Welcome back, @UserState.DisplayName! Start a new conversation or continue an existing one.
                    </MudText>
                </MudStack>
            </MudPaper>
        </MudItem>
    </MudGrid>
</MudPaper>

@code {
    // Future implementation will include:
    // - Real-time messaging
    // - Conversation list
    // - Message history
    // - File sharing
    // - Typing indicators
}
